{
  "$schema": "./tunnel-config.schema.json",
  "ingress": [
    {
      "hostname": "app.example.com",
      "service": "http://app:8080",
      "auth": {
        "access": {
          "emailDomain": "example.com",
          "sessionDuration": "24h"
        }
      }
    },
    {
      "hostname": "api.example.com",
      "path": "/v1/*",
      "service": "http://api:3000",
      "auth": { "apiKey": true },
      "originRequest": {
        "connectTimeout": "60s"
      }
    },
    {
      "service": "http_status:404"
    }
  ]
}
