# Cloudflare API Configuration
# Create an API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account: Cloudflare Tunnel (Edit), Zone: DNS (Edit)
# Add Account: Access: Apps and Policies (Edit) + Access: Service Tokens (Edit) if using ACCESS_ENABLED
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Tunnel name (will be created if it doesn't exist)
TUNNEL_NAME=my-tunnel

# Cloudflare Access (optional — protects tunnel with service token auth)
# ACCESS_ENABLED=true
