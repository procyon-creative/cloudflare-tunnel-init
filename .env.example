# Cloudflare API Configuration
# Create an API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account: Cloudflare Tunnel (Edit), Zone: DNS (Edit)
# Add Zone: Firewall Services (Write) if using API_KEY
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Tunnel name (will be created if it doesn't exist)
TUNNEL_NAME=my-tunnel

# API key auth (optional — standard Bearer token, enforced at Cloudflare edge)
# API_KEY=sk-change-me
